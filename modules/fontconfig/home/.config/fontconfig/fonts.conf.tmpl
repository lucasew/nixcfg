<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "urn:fontconfig:fonts.dtd">
<fontconfig>
  <alias>
    <family>serif</family>
    <prefer>
      <family>{{ .root.modules.fontconfig.config.serif }}</family>
    </prefer>
  </alias>
  <alias>
    <family>sans</family>
    <prefer>
      <family>{{ .root.modules.fontconfig.config.sans_serif }}</family>
    </prefer>
  </alias>
  <alias>
    <family>monospace</family>
    <prefer>
      <family>{{ .root.modules.fontconfig.config.monospace }}</family>
    </prefer>
  </alias>
  <alias>
    <family>emoji</family>
    <prefer>
      <family>{{ .root.modules.fontconfig.config.emoji }}</family>
    </prefer>
  </alias>
</fontconfig>
