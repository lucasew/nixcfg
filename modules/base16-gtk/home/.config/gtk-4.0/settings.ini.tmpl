{{- $c := .root.modules.base16.config -}}
{{- $gtk := index .root.modules "base16-gtk" -}}
{{- $theme := $gtk.config.theme_name -}}
[Settings]
gtk-theme-name={{ $theme }}
gtk-icon-theme-name={{ $gtk.config.icon_theme }}
gtk-font-name={{ $gtk.config.font_name }}
gtk-cursor-theme-name={{ $gtk.config.cursor_theme }}
gtk-cursor-theme-size={{ $gtk.config.cursor_size }}
{{- if $c.dark_mode }}
gtk-application-prefer-dark-theme=1
{{- else }}
gtk-application-prefer-dark-theme=0
{{- end }}
