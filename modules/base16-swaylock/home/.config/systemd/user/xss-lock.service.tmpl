[Unit]
Description=Screen lock on X idle/suspend
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=/run/current-system/sw/bin/xss-lock --transfer-sleep-lock -- /home/lucasew/.local/bin/lock-screen
Restart=always
RestartSec=1

[Install]
WantedBy=graphical-session.target
