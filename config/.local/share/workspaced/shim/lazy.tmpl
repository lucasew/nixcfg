{{- range $name, $tool := .LazyTools }}
{{- $bins := $tool.Bins }}
{{- if eq (len $bins) 0 }}
  {{- $binName := $tool.Alias }}
  {{- if not $binName }}
    {{- $parts := split $name ":" }}
    {{- $binName = last $parts }}
    {{- $parts = split $binName "/" }}
    {{- $binName = last $parts }}
  {{- end }}
  {{- $bins = list $binName }}
{{- end }}
{{- range $bins }}
{{- file . "0755" }}
#!/usr/bin/env bash
set -euo pipefail


_workspaced="{{ home }}/.local/bin/workspaced"
_tool_name="{{ $name }}"
_bin_name="{{ . }}"

exec "$_workspaced" open lazy --home --bin "$_bin_name" "$_tool_name" -- "$@"
{{- endfile }}
{{- end }}
{{- end }}
