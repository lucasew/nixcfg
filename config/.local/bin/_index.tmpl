{{- /* Script x: adds lazy shims to PATH */ -}}
{{- file "x" "0755" }}
#!/usr/bin/env bash
exec "{{ home }}/.local/bin/workspaced" open exec -p "{{ userDataDir }}/shim/lazy" "$@"
{{- endfile }}

{{- /* Global shims for tools */ -}}
{{- range $name, $tool := .LazyTools }}
    {{- if $tool.Global }}
        {{- $bins := $tool.Bins }}
        {{- if eq (len $bins) 0 }}
            {{- $binName := $tool.Alias }}
            {{- if not $binName }}
                {{- $parts := split $name ":" }}
                {{- $binName = last $parts }}
                {{- $parts = split $binName "/" }}
                {{- $binName = last $parts }}
            {{- end }}
            {{- $bins = list $binName }}
        {{- end }}
        {{- range $bins }}
            {{- file . "0755" }}
#!/usr/bin/env bash
exec "{{ home }}/.local/bin/workspaced" open lazy --home --bin "{{ . }}" "{{ $name }}" -- "$@"
            {{- endfile }}
        {{- end }}
    {{- end }}
{{- end }}
