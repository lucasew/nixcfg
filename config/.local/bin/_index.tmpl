

{{- /* Script x: adds lazy shims to PATH */ -}}
{{- file "x" "0755" }}
#!/usr/bin/env bash
exec "{{ home }}/.local/bin/workspaced" open exec -p "{{ userDataDir }}/shim/lazy" "$@"
{{- endfile }}

{{- /* Global shims for tools - skip mise and workspaced (handled above) */ -}}
{{- range $name, $tool := .LazyTools }}
    {{- if $tool.Global }}
        {{- $pkg := $tool.Pkg }}{{ if not $pkg }}{{ $pkg = $name }}{{ end }}
        {{- $bins := $tool.Bins }}
        {{- if eq (len $bins) 0 }}
            {{- $binName := $tool.Alias }}
            {{- if not $binName }}
                {{- $parts := split $name ":" }}
                {{- $binName = last $parts }}
                {{- $parts = split $binName "/" }}
                {{- $binName = last $parts }}
            {{- end }}
            {{- $bins = list $binName }}
        {{- end }}
        {{- range $bins }}
            {{- file . "0755" }}
#!/usr/bin/env bash
exec "{{ home }}/.local/bin/mise" exec "{{ printf "%s@%s" $pkg $tool.Version }}" -- "{{ home }}/.local/bin/x" "{{ . }}" "$@"
            {{- endfile }}
        {{- end }}
    {{- end }}
{{- end }}
