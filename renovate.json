{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "branchNameStrict": true,
  "extends": [
    "config:recommended",
    "github>lewtec/renovate-config:base"
  ],
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "jsonata",
      "fileFormat": "json",
      "managerFilePatterns": [
        "/(^|/)workspaced\\.lock\\.json$/"
      ],
      "matchStrings": [
        "dependencies.{\"depName\": depName, \"currentValue\": currentValue, \"datasource\": datasource, \"packageName\": packageName, \"versioning\": versioning}"
      ]
    }
  ],
  "packageRules": [
    {
      "automerge": true,
      "matchDepTypes": "required_provider",
      "matchManagers": [
        "terraform"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    }
  ]
}
